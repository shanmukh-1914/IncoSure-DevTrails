# Frontend Environment Configuration for IncoSure (Frontend-Only)

# Backend Configuration
# Set to "false" to run frontend-only with localStorage for data persistence
# Set to "true" to connect to a backend API (not available in current setup)
VITE_USE_BACKEND=false

# API Base URL (only used if VITE_USE_BACKEND=true)
# Default is /api which proxies to http://localhost:8081 (see vite.config.js)
# VITE_API_BASE_URL=http://localhost:8081

# Note: All data is persisted in browser localStorage
# No external services or databases are required
